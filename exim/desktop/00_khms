# Exim4 DKIM configuration for master (desktop.dnstunnel.khms)
# This configuration signs outgoing mail with khms.eu domain
# See: /etc/exim4/conf.d/main/00_khms for deployment location

DKIM_CANON = relaxed
DKIM_DOMAIN = khms.eu
DKIM_PRIVATE_KEY = /etc/exim4/dkim/khms.eu.key
DKIM_SELECTOR = desktop_1
DKIM_SIGN_HEADERS = from:to:cc:date:subject
